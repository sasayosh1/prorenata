    "_type": "block",
    "children": [
      {
        "_key": "span-vd3gk96ev",
        "_type": "span",
        "marks": [],
        "text": "👟 快適なワークシューズをお探しの方へ："
      }
    ],
    "markDefs": [],
    "style": "normal"
  },
  {
    "_key": "45e5275b-6c64-43ce-b9ff-15818f717bfe",
